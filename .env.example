PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/autoadvant
CORS_ORIGIN=http://localhost:8080
PUBLIC_API_URL=http://localhost:4000
STORAGE_ROOT=./apps/api/uploads

# Firebase Admin SDK credentials
FIREBASE_PROJECT_ID="autoadvant-dev"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-fbsvc@autoadvant-dev.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
FIREBASE_DATABASE_URL="hhttps://autoadvant-dev-default-rtdb.asia-southeast1.firebasedatabase.app"

# SMTP settings (required for verification email delivery when creating staff from admin)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password-or-app-password
MAIL_FROM="Auto Advant <autoadvantplatform@gmail.com>"